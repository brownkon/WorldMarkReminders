# ============================================
# WorldMark Scheduler — Environment Variables
# ============================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control!

# --- WorldMark Portal Credentials ---
WORLDMARK_USERNAME=your_worldmark_email
WORLDMARK_PASSWORD=your_worldmark_password

# --- Ticketmaster Discovery API (Free) ---
# Sign up: https://developer.ticketmaster.com/
TICKETMASTER_API_KEY=your_ticketmaster_api_key

# --- Notifications (ntfy.sh — Free) ---
NTFY_TOPIC=your-unique-topic
NTFY_SERVER=https://ntfy.sh
NOTIFICATION_DAILY_LIMIT=20

# --- Apple Push Notifications ---
APNS_KEY_ID=your_apns_key_id
APNS_TEAM_ID=your_apns_team_id
APNS_KEY_PATH=./certs/AuthKey.p8
APNS_BUNDLE_ID=com.yourname.worldmarkscheduler

# --- Server Config ---
PORT=3000
API_KEY=generate_a_random_api_key_here
NODE_ENV=development

# --- Scheduling (Cron Expressions) ---
RESORT_REFRESH_CRON=0 0 1 */3 *
EVENT_DISCOVERY_CRON=0 0 * * 1
AVAILABILITY_CHECK_CRON=0 6 * * *

# --- Ranking Config ---
CREDIT_VALUE_CENTS=10
MIN_PROFIT_THRESHOLD=60
EVENT_SEARCH_RADIUS_MILES=30
TOP_OPPORTUNITIES_COUNT=50

# --- Database ---
DATABASE_PATH=./data/worldmark.db
